{
  "compilerOptions": {
    "lib": ["ES2022", "dom"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "noImplicitReturns": true,
    "strictFunctionTypes": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "jsx": "react",
    "jsxFactory": "m"
  },
  "include": [
    "./bin/*.ts",
    "./lib/**/*",
    "./ui/**/*",
    "./test/**/*",
    "./build/**/*"
  ]
}
