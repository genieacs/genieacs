{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "types": [],
    "strict": false,
    "noImplicitThis": true,
    "strictBindCallApply": true,
    "useUnknownInCatchVariables": true,
    "moduleDetection": "force"
  },
  "include": ["./*.js", "./*.jsx", "./*.d.ts"]
}
